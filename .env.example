# CivicLens Environment Variables
# Copy to .env.local and fill in values. Never commit .env.local.

# ─── Supabase ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Data Source APIs ───────────────────────────────────────────────
OPENSTATES_API_KEY=your-openstates-api-key
# Get one free at https://openstates.org/accounts/signup/

LEGISCAN_API_KEY=your-legiscan-api-key
# Get one free at https://legiscan.com/user/register

# YouTube Data API (optional — for meeting video metadata)
YOUTUBE_API_KEY=your-youtube-api-key

# ─── Model APIs ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
# For complex query routing (Claude Sonnet)

GOOGLE_AI_API_KEY=your-google-ai-api-key
# For embeddings (Gemini embedding) and simple queries (Gemini Flash)

# ─── Application Config ────────────────────────────────────────────
# Model routing threshold — queries retrieving chunks from this many
# or more distinct documents are routed to Claude API
MODEL_ROUTING_DOC_THRESHOLD=3

# Maximum chunks to retrieve for RAG context
RAG_TOP_K=8

# Embedding model selection: "gemini" or "minilm"
EMBEDDING_MODEL=gemini
